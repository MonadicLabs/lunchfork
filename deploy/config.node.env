# lunchfork node-hitl configuration
# Copy to /etc/lunchfork/config.env and edit for each node

# ---- Node identity ----
# MUST be unique within the fleet — use hostname or UUID
NODE_ID=node-001
NODE_TYPE=ground
# Options: ground | uav | vehicle

# ---- Communication ----
COMM_TRANSPORT=mqtt
# Point to master IP/hostname
COMM_BROKER_URL=mqtt://192.168.1.100:1883

# ---- SDR hardware ----
SDR_DRIVER=rtlsdr
# Options: rtlsdr | hackrf | limesdr
SDR_FREQ_CENTER_HZ=433920000
SDR_SAMPLE_RATE=2048000
# RTL-SDR: 0–49 (dB), HackRF: 0–47 (dB)
SDR_GAIN=40

# ---- FFT ----
FFT_SIZE=2048
FFT_OVERLAP=0.5

# ---- Frequency detection ----
FREQ_CLUSTER_BW_HZ=25000
FREQ_CLUSTER_THRESHOLD_DBM=-90

# ---- GPS ----
# Options: gpsd | nmea | static
GPS_SOURCE=gpsd
GPS_DEVICE=/dev/ttyACM0
# Used only if GPS_SOURCE=static
GPS_STATIC_LAT=43.530
GPS_STATIC_LON=5.450
GPS_STATIC_ALT_M=200

# ---- IQ replay (optional) ----
# Leave empty for live SDR capture
# Set to file path for replay mode: /path/to/capture.iq
REPLAY_FILE=

# ---- Logging ----
LOG_LEVEL=INFO
