# lunchfork master configuration
# Copy to /etc/lunchfork/config.env and edit for your deployment

# ---- Communication ----
COMM_TRANSPORT=mqtt
COMM_BROKER_URL=mqtt://localhost:1883

# ---- Inference backend ----
# Options: onnx-cpu | onnx-cuda | pytorch-cuda | pytorch-cpu
# Use onnx-cpu if no GPU available (latency 3-10s, sufficient for UAV loitering)
# Use onnx-cuda or pytorch-cuda with GPU (latency <1s)
INFERENCE_BACKEND=onnx-cpu

# ---- Model checkpoints ----
MODEL_DIFFUSION_PATH=/opt/lunchfork/data/checkpoints/diffusion_vhf_v1.onnx
MODEL_SR_PATH=/opt/lunchfork/data/checkpoints/sr_vhf_v1.onnx

# ---- Terrain ----
TERRAIN_CACHE_DIR=/opt/lunchfork/data/terrain
# Preferred source: copernicus (25m, Europe) | srtm (30m, global) | ign-rge (1m, France)
TERRAIN_PREFER=copernicus

# ---- Pipeline grid ----
GRID_COARSE_SIZE=256
GRID_FINE_SIZE=256
SR_FACTOR=4
# Trigger fine inference when position std drops below this (metres)
ZOOM_TRIGGER_STD_M=500

# ---- Particle filter ----
PF_N_PARTICLES=500
# Reduce to 200 if CPU is constrained; increase to 2000+ with GPU
PF_MOTION_MODEL=constant_velocity
PF_ADAPTIVE_MOTION=true

# ---- Sliding window ----
SLIDING_WINDOW_SEC=30
SLIDING_WINDOW_ADAPTIVE=true

# ---- Frequency clustering ----
# Merge channels within this bandwidth (Hz)
FREQ_CLUSTER_BW_HZ=25000
# Discard signals below this threshold (dBm)
FREQ_CLUSTER_THRESHOLD_DBM=-90

# ---- Logging ----
LOG_LEVEL=INFO
